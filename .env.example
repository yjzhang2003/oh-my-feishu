# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Feishu (Lark)
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_ENCRYPT_KEY=optional_encrypt_key
FEISHU_VERIFICATION_TOKEN=optional_verification_token

# GitHub
GITHUB_TOKEN=ghp_your_github_token
GITHUB_REPO_OWNER=your_org
GITHUB_REPO_NAME=your_repo

# Agent
REPO_ROOT=/absolute/path/to/target/repo
AGENT_LOG_LEVEL=INFO
AGENT_MAX_DIFF_FILES=10
AGENT_MAX_DIFF_LINES=500
