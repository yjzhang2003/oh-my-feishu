---
const { items, columns = 3 } = Astro.props;
---

<div class={`feature-grid columns-${columns}`}>
  {items.map((item: string | [string, string]) => {
    const title = Array.isArray(item) ? item[0] : item;
    const text = Array.isArray(item) ? item[1] : '';
    return (
      <div class="feature-tile">
        <strong>{title}</strong>
        {text && <p>{text}</p>}
      </div>
    );
  })}
</div>
