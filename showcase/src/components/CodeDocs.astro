---
const { docs } = Astro.props;
const githubBase = 'https://github.com/yjzhang2003/oh-my-feishu/blob/main/';
const isFilePath = (file: string) => /\.[a-z0-9]+$/i.test(file);
const escapeHtml = (value: string) =>
  value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
const inlineMarkdown = (value: string) =>
  escapeHtml(value).replace(/`([^`]+)`/g, '<code>$1</code>');
---

<section class="code-doc-page">
  <aside class="code-sidebar" aria-label="核心代码目录">
    <p class="eyebrow">Core code</p>
    <h2>核心代码展示</h2>
    <nav>
      {docs.map((doc: { id: string; nav: string }) => (
        <a href={`#${doc.id}`}>{doc.nav}</a>
      ))}
    </nav>
  </aside>

  <article class="markdown-reader">
    <header class="doc-intro">
      <h1>核心部分代码展示</h1>
    </header>

    {docs.map((doc: {
      id: string;
      nav: string;
      title: string;
      files: string[];
      why?: string;
      overview?: string;
      bullets?: string[];
      flow?: string[];
      snippetTitle: string;
      snippet: string;
    }) => (
      <section class="doc-section" id={doc.id}>
        <div class="doc-heading">
          <p class="eyebrow">{doc.nav}</p>
          <h2>{doc.title}</h2>
        </div>
        <div class="doc-copy">
          {doc.overview ? (
            <p class="overview-copy" set:html={inlineMarkdown(doc.overview)} />
          ) : (
            <>
              <h3>代码作用</h3>
              <p set:html={inlineMarkdown(doc.why || '')} />
            </>
          )}
          <h3>{doc.flow ? '链路结构' : '拆解要点'}</h3>
          <ul>
            {(doc.flow || doc.bullets || []).map((item) => <li set:html={inlineMarkdown(item)} />)}
          </ul>
        </div>

        <div class="doc-files">
          <h3>相关文件</h3>
          <div class="file-link-grid">
            {doc.files.map((file) => {
              const linked = isFilePath(file);
              return (
                linked ? (
                  <a class="file-link-card" href={`${githubBase}${file}`} target="_blank" rel="noreferrer">
                    <span>{file}</span>
                    <small>GitHub</small>
                  </a>
                ) : (
                  <span class="file-link-card muted">
                    <span>{file}</span>
                    <small>目录</small>
                  </span>
                )
              );
            })}
          </div>
        </div>
        <div class="snippet-block">
          <div class="snippet-title">
            <span>{doc.snippetTitle}</span>
          </div>
          <pre><code>{doc.snippet}</code></pre>
        </div>
      </section>
    ))}
  </article>
</section>
