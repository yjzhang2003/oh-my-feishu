---
import { routes } from '@/data/showcase';
import '@/styles/global.css';

const { title, description = 'oh-my-feishu 作品展示', deckControls = true } = Astro.props;
const baseUrl = import.meta.env.BASE_URL || '/';
const basePath = baseUrl.endsWith('/') && baseUrl !== '/' ? baseUrl.slice(0, -1) : baseUrl === '/' ? '' : baseUrl;
const currentPath = Astro.url.pathname.replace(basePath, '') || '/';
const withBase = (href: string) => `${basePath}${href}`.replace(/\/{2,}/g, '/');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1f8cff" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title} | oh-my-feishu</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase('/')}>
        <span class="brand-mark">omf</span>
        <span>oh-my-feishu</span>
      </a>
      <nav class="top-nav" aria-label="展示页面">
        {routes.map((route) => (
          <a class={currentPath === route.href ? 'active' : ''} href={withBase(route.href)}>
            <span>{route.eyebrow}</span>
            {route.label}
          </a>
        ))}
      </nav>
      <a class="github-link" href="https://github.com/yjzhang2003/oh-my-feishu" target="_blank" rel="noreferrer" aria-label="打开 GitHub 仓库">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38v-1.33c-2.23.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.06-.49.06-.49.8.06 1.22.82 1.22.82.71 1.22 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.65 7.65 0 0 1 8 3.89c.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.19c0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
        </svg>
      </a>
    </header>
    <main class="slide-deck" id="slide-deck" tabindex="0">
      <slot />
    </main>
    {deckControls && (
      <div class="deck-controls" aria-label="页面切换">
        <button type="button" data-deck-prev aria-label="上一屏">‹</button>
        <span data-deck-status>1</span>
        <button type="button" data-deck-next aria-label="下一屏">›</button>
      </div>
    )}
    <footer class="site-footer">
      <span>Claude Code x Feishu x lark-cli</span>
      <span>静态作品展示</span>
    </footer>
    <script>
      const deck = document.querySelector('[data-deck]') || document.getElementById('slide-deck');
      const prev = document.querySelector('[data-deck-prev]');
      const next = document.querySelector('[data-deck-next]');
      const status = document.querySelector('[data-deck-status]');
      const slides = deck ? Array.from(deck.children) : [];

      const currentIndex = () => {
        if (!deck || slides.length === 0) return 0;
        return Math.round(deck.scrollLeft / deck.clientWidth);
      };

      const updateStatus = () => {
        if (!status || slides.length === 0) return;
        status.textContent = `${currentIndex() + 1}/${slides.length}`;
        const controls = document.querySelector('.deck-controls');
        if (controls) controls.toggleAttribute('hidden', slides.length <= 1);
      };

      const go = (direction) => {
        if (!deck) return;
        deck.scrollTo({
          left: (currentIndex() + direction) * deck.clientWidth,
          behavior: 'smooth',
        });
      };

      prev?.addEventListener('click', () => go(-1));
      next?.addEventListener('click', () => go(1));
      deck?.addEventListener('scroll', () => window.requestAnimationFrame(updateStatus), { passive: true });
      window.addEventListener('resize', updateStatus);
      window.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') go(-1);
        if (event.key === 'ArrowRight') go(1);
      });
      updateStatus();
    </script>
  </body>
</html>
