---
const { module } = Astro.props;
---

<article class="code-module" id={module.anchor}>
  <div class="module-copy">
    <p class="eyebrow">Core module</p>
    <h2>{module.title}</h2>
    <p>{module.summary}</p>
    <ul class="check-list">
      {module.points.map((point: string) => <li>{point}</li>)}
    </ul>
    <div class="file-list">
      {module.files.map((file: string) => <code>{file}</code>)}
    </div>
  </div>
  <pre class="code-window"><code>{module.snippet}</code></pre>
</article>
