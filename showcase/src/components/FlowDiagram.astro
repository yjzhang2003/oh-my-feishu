---
const { steps } = Astro.props;
---

<div class="flow-diagram">
  {steps.map((step: string, index: number) => (
    <>
      <div class="flow-node">
        <span>{String(index + 1).padStart(2, '0')}</span>
        <strong>{step}</strong>
      </div>
      {index < steps.length - 1 && <div class="flow-line" aria-hidden="true"></div>}
    </>
  ))}
</div>
