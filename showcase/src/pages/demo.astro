---
import Layout from '@/components/Layout.astro';
import PageHero from '@/components/PageHero.astro';
import FlowDiagram from '@/components/FlowDiagram.astro';

const steps = ['飞书发起请求', '选择目录或历史会话', 'Claude Code 在本地执行', '流式卡片回传过程', '结果沉淀到飞书'];
---

<Layout title="Demo 展示">
  <PageHero
    eyebrow="Demo"
    title="一条消息触发完整 AI coding 流程"
    description="Demo 可以围绕“用户在飞书中请求分析或修复项目问题”展开，展示从移动端入口到本地 Claude Code 执行，再到飞书卡片回传的闭环。"
    tone="demo"
  >
    <div class="hero-panel">
      <p class="eyebrow">Suggested recording</p>
      <h2>建议录屏结构</h2>
      <p>先展示 CLI 扫码与服务启动，再进入飞书菜单，绑定项目目录，发送代码分析请求，最后展示流式卡片和结果。</p>
    </div>
  </PageHero>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">Storyboard</p>
        <h2>演示链路</h2>
      </div>
    </div>
    <FlowDiagram steps={steps} />
  </section>

  <section class="section">
    <div class="split-layout">
      <div class="callout">
        <p class="eyebrow">Demo script</p>
        <h2>可讲解重点</h2>
        <p>这个项目不是把模型 API 包一层聊天机器人，而是把 Claude Code 的本地工程能力接入飞书，使团队协作工具可以承接 AI 执行过程与结果。</p>
      </div>
      <div class="feature-grid columns-2">
        <div class="feature-tile"><strong>入口完整</strong><p>CLI onboarding、飞书 Bot 注册、PM2 服务管理构成可演示的安装流程。</p></div>
        <div class="feature-tile"><strong>过程可见</strong><p>Claude Code 的文本、思考和工具调用过程通过飞书卡片流式呈现。</p></div>
        <div class="feature-tile"><strong>上下文真实</strong><p>会话绑定到本地目录和历史 session，AI 能理解项目代码。</p></div>
        <div class="feature-tile"><strong>可继续扩展</strong><p>Gateway 和 skills 让后续自动化能力可以插件化增加。</p></div>
      </div>
    </div>
  </section>
</Layout>
