---
import DocsLayout from '@/components/DocsLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { docHref, sortDocs, toDocNavItem } from '@/data/docs';

export async function getStaticPaths() {
  const docs = sortDocs(await getCollection('docs'));
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc, docs },
  }));
}

const { doc, docs } = Astro.props as { doc: CollectionEntry<'docs'>; docs: CollectionEntry<'docs'>[] };
const { Content, headings } = await render(doc);
const navDocs = docs.map(toDocNavItem);
---

<DocsLayout title={doc.data.title} description={doc.data.summary} activeSlug={doc.id} docs={navDocs}>
  <header class="docs-hero">
    <p class="eyebrow">{doc.data.eyebrow}</p>
    <h1>{doc.data.title}</h1>
    <p>{doc.data.summary}</p>
    <div class="docs-tags">
      {doc.data.tags.map((tag) => <span>{tag}</span>)}
    </div>
  </header>

  <div class="docs-detail-layout">
    <div class="docs-markdown">
      <Content />
    </div>

    <aside class="docs-toc" aria-label="页面章节">
      <strong>本页目录</strong>
      {headings.filter((heading) => heading.depth === 2).map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)}
    </aside>
  </div>

  <nav class="docs-next">
    {docs.map((item) => (
      item.id !== doc.id && <a href={docHref(item.id)}>{item.data.title}</a>
    ))}
  </nav>
</DocsLayout>
