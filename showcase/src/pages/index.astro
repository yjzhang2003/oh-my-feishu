---
import Layout from '@/components/Layout.astro';

const asset = (name: string) => `${import.meta.env.BASE_URL}pics/${name}`;

const startSteps = [
  ['准备环境', '确认终端可以运行 claude --version 和 lark-cli --version。Claude Code 负责对话与执行，lark-cli 负责飞书能力调用。'],
  ['全局安装', 'npm install -g oh-my-feishu'],
  ['启动配置', '运行 oh-my-feishu，跟随交互式 CLI 完成检查、扫码授权和后台服务启动。'],
  ['进入飞书', '在飞书里发送 /menu，开始管理直接对话、目录会话、历史会话和自动化服务。'],
];

const abilities = [
  ['用菜单管理工作上下文', '通过 /menu 切换直接对话、目录会话和历史会话。', '/code/'],
  ['在飞书里和 Claude Code 对话', '不用切回终端，直接在飞书中讨论代码、查看回复和继续执行任务。', '/ai/'],
  ['继续一段 Claude Code 会话', '恢复电脑上的历史 session，或者绑定任意本地目录继续工作。', '/code/#session-binding'],
  ['使用 Web Monitor 自动化服务', '注册 traceback 地址后，后台轮询错误变化并触发 AI 分析或修复。', '/gateway/'],
  ['让 Claude Code 使用飞书能力', '通过 lark-cli skills 操作文档、消息、日历、表格、任务和云盘。', '/skill/'],
  ['只安装飞书能力插件', '把 oh-my-feishu 作为 Claude plugin 安装到现有项目。', '/skill/'],
];
---

<Layout title="首页">
  <section class="readme-hero">
    <div class="readme-hero-copy">
      <p class="eyebrow">oh-my-feishu</p>
      <h1>在飞书里使用 Claude Code 的最佳方式</h1>
      <p>把飞书消息、Claude Code、本地项目目录和 lark-cli skills 连接起来，让 Claude Code 可以在飞书里被发起、继续、协作和回传结果。</p>
      <div class="readme-actions" aria-label="首页快捷入口">
        <a href="#start">开始使用</a>
        <a href="#abilities">你可以做什么</a>
        <a href="/code/">代码展示</a>
      </div>
    </div>
    <div class="hero-command-panel" aria-label="安装和启动命令">
      <p class="eyebrow">Quick start</p>
      <pre><code>npm install -g oh-my-feishu
oh-my-feishu</code></pre>
    </div>
  </section>

  <section class="readme-section" id="start">
    <div class="section-header">
      <div>
        <p class="eyebrow">Getting started</p>
        <h2>如何开始</h2>
      </div>
      <p class="section-lead">README 里的安装和启动路径整理成四步，右滑到这一屏就能按顺序演示。</p>
    </div>
    <div class="start-grid">
      {startSteps.map(([title, text], index) => (
        <article>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
    <div class="install-strip">
      <code>npm install -g oh-my-feishu</code>
      <code>oh-my-feishu</code>
    </div>
    <figure class="readme-wide-media">
      <img src={asset('cli-demo.png')} alt="CLI onboarding 与扫码配置" loading="lazy" />
      <figcaption>CLI 会带你完成检查、扫码和服务启动。</figcaption>
    </figure>
  </section>

  <section class="readme-section" id="abilities">
    <div class="section-header">
      <div>
        <p class="eyebrow">What you can do</p>
        <h2>你可以做什么</h2>
      </div>
    </div>
    <div class="ability-grid">
      {abilities.map(([title, text, href]) => (
        <a href={href}>
          <strong>{title}</strong>
          <span>{text}</span>
        </a>
      ))}
    </div>
    <div class="readme-media-pair">
      <figure>
        <img src={asset('menu-demo.jpeg')} alt="飞书菜单卡片" loading="lazy" />
        <figcaption>/menu 管理工作上下文</figcaption>
      </figure>
      <figure>
        <img src={asset('talk-demo.gif')} alt="在飞书里和 Claude Code 对话" loading="lazy" />
        <figcaption>飞书内直接对话 Claude Code</figcaption>
      </figure>
    </div>
  </section>
</Layout>
